generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth 관련 모델
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 사용자
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 구독 정보
  plan          String    @default("free") // free, pro
  bookmarkLimit Int       @default(20)

  // 뉴스레터 설정
  newsletterEnabled  Boolean @default(true)
  newsletterDay      String  @default("sunday") // 매주 발행 요일
  newsletterTime     String  @default("21:00")
  newsletterTimezone String  @default("Asia/Seoul")

  accounts      Account[]
  sessions      Session[]
  bookmarks     Bookmark[]
  categories    Category[]
  reminders     Reminder[]
  newsletters   Newsletter[]
  notifications Notification[]
}

// 카테고리
model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#0ea5e9")
  userId    String
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]

  @@unique([userId, name])
}

// 북마크
model Bookmark {
  id          String   @id @default(cuid())
  url         String
  title       String?
  description String?
  thumbnail   String?
  summary     String?  // AI 3줄 요약 (Gemini 생성)
  tags        String?  // 쉼표 구분 태그 (Gemini 분류)
  questions   String?  // AI 생성 연관 질문 3가지 (JSON 배열)
  keywords    String?  // 지식 그래프용 키워드 (쉼표 구분)
  source      String   @default("manual") // manual, youtube, bookmarklet
  status      String   @default("pending") // pending, completed, failed, deleted
  isImportant Boolean  @default(false) // Spaced Repetition 대상
  lastChecked DateTime? // 마지막 유효성 검사 시점
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId     String
  categoryId String?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reminders Reminder[]

  @@index([userId, status])
  @@index([userId, categoryId])
  @@index([userId, createdAt])
}

// 리마인더/알람 (Spaced Repetition 포함)
model Reminder {
  id           String   @id @default(cuid())
  remindAt     DateTime
  message      String?
  type         String   @default("custom") // custom, spaced_1d, spaced_7d, spaced_30d
  isNotified   Boolean  @default(false)
  createdAt    DateTime @default(now())

  userId     String
  bookmarkId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)

  @@index([remindAt, isNotified])
  @@index([userId])
}

// 뉴스레터
model Newsletter {
  id        String   @id @default(cuid())
  title     String
  content   String   // AI 생성 뉴스레터 본문 (HTML)
  weekStart DateTime // 해당 주 시작일
  weekEnd   DateTime // 해당 주 종료일
  sentAt    DateTime?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
}

// 알림 (일반 알림, 링크 삭제 알림 등)
model Notification {
  id        String   @id @default(cuid())
  type      String   // link_deleted, reminder, newsletter, spaced_repetition
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?  // JSON 형태 추가 데이터
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
